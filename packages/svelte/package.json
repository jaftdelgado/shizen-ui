{
  "name": "@shizen-ui/svelte",
  "version": "0.1.0-alpha.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "svelte-package -i src && bun scripts/generate-pkg.ts",
    "dev": "svelte-package -i src --watch",
    "add-component": "bun scripts/add-component.ts"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "svelte": "^5.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.4.1"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.4",
    "@shizen-ui/styles": "workspace:*",
    "focus-trap": "^8.0.0"
  }
}
