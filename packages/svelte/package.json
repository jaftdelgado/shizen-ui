{
  "name": "@shizen-ui/svelte",
  "version": "0.0.1",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "svelte": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "svelte": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./contexts/*": {
      "types": "./src/contexts/*.ts",
      "import": "./src/contexts/*.ts"
    },
    "./components/*": "./src/components/*.svelte"
  },
  "scripts": {
    "add-component": "bun scripts/add-component.ts"
  },
  "files": [
    "src"
  ],
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "svelte": "^5.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.4.1"
  },
  "dependencies": {
    "@shizen-ui/styles": "workspace:*"
  }
}
