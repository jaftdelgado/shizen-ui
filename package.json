{
  "name": "shizen-ui",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/styles",
    "packages/svelte"
  ],
  "scripts": {
    "dev": "bun --filter \"*\" dev",
    "build": "bun --filter \"*\" build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "version": "changeset version",
    "release": "changeset publish",
    "add-component": "bun --filter @shizen-ui/svelte add-component"
  },
  "overrides": {
    "vite": "^6.0.0"
  },
  "trustedDependencies": [
    "tailwindcss"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@tailwindcss/vite": "^4.0.0",
    "@types/bun": "latest",
    "eslint": "^9.39.2",
    "eslint-plugin-svelte": "^3.14.0",
    "prettier": "^3.7.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.4.1",
    "svelte": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.52.0"
  }
}
