---
import "../styles/global.css";
import Sidebar from "@components/astro/Sidebar.astro";
import TableOfContents from "@components/astro/TableOfContents.astro";
import { ViewTransitions } from "astro:transitions";

interface Props {
  title: string;
  headings: { depth: number; slug: string; text: string }[];
}

const { title, headings } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | Shizen UI</title>
    <ViewTransitions />
  </head>
  <body class="bg-background font-sans">
    <header
      class="sticky top-0 z-40 w-full border-b border-separator bg-surface/90 backdrop-blur-xl"
    >
      <div class="mx-auto flex h-16 max-w-8xl items-center justify-between px-6">
        <a href="/" class="text-xl font-bold text-primary-text">Shizen UI</a>
      </div>
    </header>

    <div class="mx-auto max-w-8xl px-6">
      <div class="flex flex-col md:flex-row gap-8">
        <div transition:persist="sidebar">
          <Sidebar />
        </div>

        <main
          class="flex-auto py-10 md:pl-72 lg:pr-72 min-w-0 flex justify-center"
          transition:animate="fade"
        >
          <article class="prose-content w-full max-w-160">
            <slot />
          </article>
        </main>

        <div transition:persist="toc">
          <TableOfContents headings={headings} />
        </div>
      </div>
    </div>
  </body>
</html>
