---
import "../styles/global.css";
import Sidebar from "@components/astro/Sidebar.astro";
import TableOfContents from "@components/astro/TableOfContents.astro";

interface Props {
  title: string;
  headings: { depth: number; slug: string; text: string }[];
}

const { title, headings } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | Shizen UI</title>
  </head>
  <body class="bg-background font-sans">
    <header
      class="sticky top-0 z-40 w-full border-b border-separator bg-surface/90 backdrop-blur-xl"
    >
      <div class="mx-auto flex h-16 max-w-8xl items-center justify-between px-6">
        <a href="/" class="text-xl font-bold text-primary-text">Shizen UI</a>
        <nav class="flex gap-4">
          <a
            href="https://github.com/jaftdelgado/shizen-ui"
            class="hover:text-white text-sm font-medium text-zinc-400 transition-colors"
          >
            GitHub
          </a>
        </nav>
      </div>
    </header>

    <div class="mx-auto max-w-8xl px-6">
      <div class="flex flex-col md:flex-row gap-8">
        <Sidebar />

        <main class="flex-auto py-10 md:pl-72 lg:pr-72 min-w-0 flex justify-center">
          <article class="prose-content w-full max-w-160">
            <slot />
          </article>
        </main>

        <TableOfContents headings={headings} />
      </div>
    </div>
  </body>
</html>
