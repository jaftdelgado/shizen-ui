---
import { codeToHtml } from "shiki";

interface Props {
  code: string;
  lang?: string;
  theme?: string;
  showLineNumbers?: boolean;
  isContained?: boolean;
}

const {
  code = "",
  lang = "tsx",
  theme = "github-light",
  showLineNumbers = true,
  isContained = false
} = Astro.props;

const cleanedCode = code.trim();

const highlightedCode = await codeToHtml(cleanedCode, {
  lang,
  theme,
  structure: "classic"
});
---

<div
  class:list={[
    "bg-component",
    {
      "border border-slate-200 rounded-2xl shadow-xs my-8": !isContained,
      "border-none rounded-none shadow-none": isContained
    }
  ]}
>
  <div
    class:list={[
      "py-4 overflow-x-auto font-mono shiki-container",
      { "line-numbers": showLineNumbers }
    ]}
  >
    <Fragment set:html={highlightedCode} />
  </div>
</div>

<style is:global>
  .shiki-container {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .shiki-container::-webkit-scrollbar {
    display: none;
  }

  .shiki-container pre {
    background-color: transparent !important;
    margin: 0;
    padding: 0;
    display: block;
    line-height: 1.6;
    font-size: 0.875rem;
  }

  .shiki-container code {
    display: block;
    width: fit-content;
    min-width: 100%;
    counter-reset: step;
  }

  .line {
    display: inline-block;
    width: 100%;
    padding: 0 1.5rem;
    box-sizing: border-box;
  }

  .line span {
    line-height: inherit;
  }

  .line-numbers .line {
    padding-left: 0.25rem;
  }

  .line-numbers .line::before {
    content: counter(step);
    counter-increment: step;
    width: 3rem;
    display: inline-block;
    text-align: right;
    color: var(--color-secondary-text);
    user-select: none;
    padding-right: 1rem;
    font-size: 0.875rempx;
  }
</style>
