---
import { codeToHtml } from "shiki";
import CodeBlockToggle from "@components/svelte/CodeBlockToggle.svelte";

interface Props {
  code: string;
  lang?: string;
  theme?: string;
  showLineNumbers?: boolean;
  isContained?: boolean;
  collapsible?: boolean;
}

const {
  code = "",
  lang = "tsx",
  theme = "github-light",
  showLineNumbers = true,
  isContained = false,
  collapsible = true
} = Astro.props;

const cleanedCode = code.trim();

const highlightedCode = await codeToHtml(cleanedCode, {
  lang,
  theme,
  structure: "classic"
});

const instanceId = crypto.randomUUID();
---

<div
  class:list={[
    "bg-component code-block-root",
    {
      "border border-slate-200 rounded-2xl shadow-xs my-8": !isContained,
      "border-none rounded-none shadow-none": isContained
    }
  ]}
  data-code-block={instanceId}
  data-collapsed={collapsible ? "true" : undefined}
>
  <div
    class:list={["overflow-x-auto font-mono shiki-container", { "line-numbers": showLineNumbers }]}
    data-code-content={instanceId}
  >
    <Fragment set:html={highlightedCode} />
  </div>

  {
    collapsible && (
      <div class="code-block-footer">
        <CodeBlockToggle client:load instanceId={instanceId} collapsed={true} />
      </div>
    )
  }
</div>
