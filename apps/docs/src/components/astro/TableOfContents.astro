---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const toc = headings.filter((h) => h.depth > 1 && h.depth < 4);
---

<aside class="w-full overflow-y-auto py-10" id="table-of-contents">
  <h5 class="mb-4 font-medium text-primary-text text-sm tracking-tight">En esta página</h5>
  <ul class="space-y-2 text-sm" id="toc-list">
    {
      toc.map((h) => (
        <li class={h.depth === 3 ? "pl-4" : ""}>
          <a
            href={`#${h.slug}`}
            class="toc-link text-secondary-text hover:text-accent transition-colors line-clamp-2"
            data-slug={h.slug}
          >
            {h.text}
          </a>
        </li>
      ))
    }
  </ul>
</aside>

<script>
  let tocObserver: IntersectionObserver | null = null;

  function initTocObserver() {
    const links = document.querySelectorAll(".toc-link");
    const headings = document.querySelectorAll(
      "article h2:not([data-example-container] h2), article h3:not([data-example-container] h3)"
    );

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const activeId = entry.target.id;
            links.forEach((link) => {
              const isActive = link.getAttribute("data-slug") === activeId;
              link.classList.toggle("text-secondary-text", !isActive);
              link.classList.toggle("text-accent", isActive);
              link.classList.toggle("font-medium", isActive);
            });
          }
        });
      },
      {
        rootMargin: "-100px 0px -66% 0px",
        threshold: 0
      }
    );

    headings.forEach((h) => observer.observe(h));
    return observer;
  }

  function updateTableOfContents() {
    const article = document.querySelector("article");
    if (!article) return;

    const headings = Array.from(
      article.querySelectorAll(
        "h2:not([data-example-container] *), h3:not([data-example-container] *)"
      )
    )
      .map((heading) => ({
        depth: parseInt(heading.tagName.charAt(1)),
        slug: heading.id,
        text: heading.textContent || ""
      }))
      .filter((h) => h.depth > 1 && h.depth < 4);

    const tocList = document.getElementById("toc-list");
    if (!tocList) return;

    tocList.innerHTML = headings
      .map((h) => {
        const paddingClass = h.depth === 3 ? "pl-4" : "";
        return `
          <li class="${paddingClass}">
            <a
              href="#${h.slug}"
              class="toc-link text-secondary-text hover:text-accent transition-colors line-clamp-2"
              data-slug="${h.slug}"
            >
              ${h.text}
            </a>
          </li>
        `;
      })
      .join("");

    if (tocObserver) tocObserver.disconnect();
    tocObserver = initTocObserver();
  }

  updateTableOfContents();

  document.addEventListener("astro:after-swap", () => {
    updateTableOfContents();
  });
</script>
