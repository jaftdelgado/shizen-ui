---
import CodeBlock from "./CodeBlock.astro";

interface Props {
  src?: string;
  lang?: string;
  theme?: string;
  showLineNumbers?: boolean;
}

const { src, lang = "svelte", theme, showLineNumbers = true } = Astro.props;

let code = "";

if (src) {
  const examples = import.meta.glob("/src/examples/**/*.svelte", {
    query: "?raw",
    import: "default"
  });

  const fullPath = `/src/examples/${src}`;
  const loadCode = examples[fullPath];

  if (loadCode) {
    code = (await loadCode()) as string;
  } else {
    console.warn(`[ComponentExample] No se encontró: ${fullPath}`);
  }
}
---

<div class="my-8 border border-slate-200 rounded-2xl overflow-hidden bg-transparent">
  <div class="p-8 flex items-center justify-center min-h-84">
    <slot />
  </div>

  {
    code && (
      <div class="border-t border-slate-200">
        <CodeBlock code={code} lang={lang} theme={theme} showLineNumbers={showLineNumbers} />
      </div>
    )
  }
</div>
