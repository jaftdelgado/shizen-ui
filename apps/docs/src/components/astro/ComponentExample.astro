---
import CodeBlock from "./CodeBlock.astro";

interface Props {
  src?: string;
  lang?: string;
  theme?: string;
  showLineNumbers?: boolean;
}

const { src, lang = "svelte", theme, showLineNumbers = true } = Astro.props;

let code = "";

if (src) {
  const examples = import.meta.glob("/src/examples/**/*.svelte", {
    query: "?raw",
    import: "default"
  });

  const fullPath = `/src/examples/${src}`;
  const loadCode = (await examples[fullPath]?.()) as string;

  if (loadCode) {
    code = loadCode.trim();
  } else {
    console.warn(`[ComponentExample] No se encontró: ${fullPath}`);
  }
}
---

<section
  class="my-8 border border-separator rounded-2xl overflow-hidden bg-transparent"
  aria-label="Component Example"
>
  <div class="p-8 flex items-center justify-center min-h-92">
    <slot />
  </div>

  {
    code && (
      <div class="border-t border-separator" aria-label="Component Example Code">
        <CodeBlock
          code={code}
          lang={lang}
          theme={theme}
          showLineNumbers={showLineNumbers}
          isContained
        />
      </div>
    )
  }
</section>
