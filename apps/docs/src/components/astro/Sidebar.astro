---
interface MdxModule {
  frontmatter: { title?: string };
  url?: string;
}

const files = Object.values(
  import.meta.glob<MdxModule>("../../pages/docs/components/*.mdx", { eager: true })
);

const sidebarItems = files
  .flatMap((file) => {
    const name = file.frontmatter.title ?? file.url?.split("/").pop();
    return name ? [{ name, href: file.url }] : [];
  })
  .sort((a, b) => a.name.localeCompare(b.name));

const { pathname } = Astro.url;

const isActive = (href?: string) =>
  href !== undefined && (pathname === href || pathname === `${href}/`);
---

<aside
  class="fixed top-16 bottom-0 left-[max(0px,calc(50%-45rem))] z-30 w-64 overflow-y-auto py-10 hidden md:block"
>
  <nav>
    <h5 class="mb-4 font-medium text-primary-text">Components</h5>
    <ul class="ml-1 space-y-0" id="sidebar-nav">
      {
        sidebarItems.map((item, index) => {
          const active = isActive(item.href);
          return (
            <>
              <li>
                <a
                  href={item.href}
                  data-href={item.href}
                  aria-current={active ? "page" : undefined}
                  class="text-sm sidebar-link group flex items-center transition-colors text-secondary-text hover:text-accent aria-[current=page]:text-accent"
                >
                  <span class="sidebar-line inline-block h-px w-8 shrink-0 bg-tertiary-text transition-all duration-300 ease-out group-hover:w-12 group-hover:bg-accent aria-[current=page]:w-12 aria-[current=page]:bg-accent" />
                  <span class="pl-4">{item.name}</span>
                </a>
              </li>
              {index < sidebarItems.length - 1 && (
                <li class="flex flex-col gap-2 pointer-events-none" aria-hidden="true">
                  <span class="inline-block h-px w-8 bg-tertiary-text" />
                  <span class="inline-block h-px w-8 bg-tertiary-text" />
                </li>
              )}
            </>
          );
        })
      }
    </ul>
  </nav>
</aside>

<script>
  function updateActiveLink() {
    const { pathname } = window.location;

    document.querySelectorAll<HTMLAnchorElement>(".sidebar-link").forEach((link) => {
      const href = link.dataset.href;
      const active = href !== undefined && (pathname === href || pathname === `${href}/`);
      link.setAttribute("aria-current", active ? "page" : "false");
    });
  }

  updateActiveLink();
  document.addEventListener("astro:after-swap", updateActiveLink);
</script>
